# Copy file này thành .env và điền giá trị phù hợp

# DEFAULT_JOB: module path của crawl job mặc định
DEFAULT_JOB=vietstock.chung_khoan.giao_dich_noi_bo.crawl_job

# CONVERTER: chiều chuyển đổi và đường dẫn file
CONVERTER_MODE=to_excel
CONVERTER_INPUT=data\members\TenThanh_vien\trang_bao\chu_de\chu_de_con\draft_crawled_data.parquet
MERGE_OUTPUT=data\members\merged_dataset.parquet   # để trống = dùng mặc định

# Cấu hình cho data/utils/reindex_dataset.py
REINDEX_UTIL_DATASET_PATH=data\members\merged_dataset.xlsx
